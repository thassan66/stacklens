{
  "name": "stacklens-cli",
  "version": "0.1.0",
  "description": "Local project insight dashboard for modern software stacks.",
  "type": "module",
  "bin": {
    "stacklens": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "pack:local": "npm pack",
    "verify:package": "node scripts/verify-package.js",
    "prepublishOnly": "npm test && npm run verify:package",
    "demo:spring": "node src/cli.js --no-open examples/spring-risky",
    "demo:node": "node src/cli.js --no-open examples/node-risky",
    "scan:json": "node src/cli.js --json examples/spring-risky",
    "scan:sarif": "node src/cli.js --sarif examples/spring-risky"
  },
  "keywords": [
    "developer-tools",
    "dashboard",
    "security",
    "configuration",
    "spring-boot",
    "nodejs",
    "devops"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "public",
    "scripts/verify-package.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thassan66/stacklens.git"
  },
  "bugs": {
    "url": "https://github.com/thassan66/stacklens/issues"
  },
  "homepage": "https://github.com/thassan66/stacklens#readme"
}
